    "react-icons": "^5.6.0",
    "react-turnstile": "^1.1.5",
    "resend": "^6.9.3",
    "sanity": "^5.1.0",
    "sanity-image": "^1.0.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.17",
    "three": "^0.171.0",
    "topojson-client": "^3.1.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
